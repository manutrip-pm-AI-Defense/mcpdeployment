# ============================================================================
# Remote HTTP Deployment Configuration for MCP Server
# ============================================================================
# Copy this file to .env.remote and configure for your deployment:
#   cp .env.remote.example .env.remote
#
# Then load the variables before running:
#   set -a; source .env.remote; set +a
#   uv run mcp-server-remote
# ============================================================================

# HTTP Server Configuration
# ============================================================================

# Server binding address
# - Use 0.0.0.0 to accept connections from any network interface (remote access)
# - Use 127.0.0.1 for localhost only (local testing)
MCP_REMOTE_HOST=0.0.0.0

# Server port
# - Default: 8000
# - Make sure this port is open in your firewall for remote access
MCP_REMOTE_PORT=8000


# Cisco AI Defense API Configuration (Optional)
# ============================================================================
# These are required for the scan_mcp_server tool's API analyzer feature
# Get your API key from: https://aidefense.security.cisco.com/

# Your Cisco AI Defense API Key
MCP_SCANNER_API_KEY=your_cisco_api_key_here

# Cisco AI Defense API Endpoint
# US endpoint (default): https://us.api.inspect.aidefense.security.cisco.com/api/v1
# EU endpoint: https://eu.api.inspect.aidefense.security.cisco.com/api/v1
MCP_SCANNER_ENDPOINT=https://us.api.inspect.aidefense.security.cisco.com/api/v1


# OpenAI API Configuration (Optional)
# ============================================================================
# Required for the LLM-based scanner analyzer
# Get your API key from: https://platform.openai.com/api-keys

MCP_SCANNER_LLM_API_KEY=your_openai_api_key_here


# Advanced Scanner Configuration (Optional)
# ============================================================================

# Scanner timeout in seconds (default: 30)
# MCP_SCANNER_TIMEOUT=30

# Maximum number of retries for scanner API calls (default: 3)
# MCP_SCANNER_MAX_RETRIES=3

# Skip LLM analyzer to avoid potential SSL issues (true/false)
SKIP_LLM_ANALYZER=false


# SSL Certificate Configuration (macOS/Linux)
# ============================================================================
# Uncomment if you encounter SSL certificate verification errors

# SSL_CERT_FILE=/path/to/your/venv/lib/python3.12/site-packages/certifi/cacert.pem
# REQUESTS_CA_BUNDLE=/path/to/your/venv/lib/python3.12/site-packages/certifi/cacert.pem
# CURL_CA_BUNDLE=/path/to/your/venv/lib/python3.12/site-packages/certifi/cacert.pem


# Production Deployment Notes
# ============================================================================
# For production deployments, consider:
#
# 1. Security:
#    - Use environment variable injection (not .env files) in production
#    - Enable HTTPS via reverse proxy (nginx, caddy) or platform SSL
#    - Add authentication/authorization (to be implemented)
#
# 2. Networking:
#    - Configure firewall rules to restrict access
#    - Use private networks when possible
#    - Set up rate limiting
#
# 3. Monitoring:
#    - Enable logging and monitoring
#    - Set up health check endpoints
#    - Monitor resource usage
#
# See docs/HTTP_DEPLOYMENT.md for detailed deployment guides
